#!/usr/bin/env sh
set -e

echo "› build + typecheck + lint + format"
npm run build && npm run typecheck && npm run lint && npm run format:check

# gitleaks — scan the STAGED diff for secrets before they enter a commit.
# Locally the binary is optional: if it isn't installed we warn loudly and skip,
# so contributors aren't blocked on a tool they haven't set up. CI never skips —
# .github/workflows/secret-scan.yml runs gitleaks fail-closed over full history.
echo "› gitleaks (staged diff)"
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --redact --verbose
else
  echo "  ⚠ gitleaks not installed — skipping local staged-diff scan."
  echo "    Install it (https://github.com/gitleaks/gitleaks) for pre-commit secret scanning;"
  echo "    the secret-scan CI workflow still gates every push."
fi

# fallow — block the commit on new findings in the changes you're staging.
# --health-baseline grandfathers the same known-complex functions CI does
# (.github/workflows/fallow.yml), so editing a file that merely CONTAINS a
# pre-existing god-function doesn't false-RED; genuinely new complexity (not in
# the baseline) still blocks. Keeps local === CI.
echo "› fallow"
npx fallow audit --base HEAD --health-baseline .fallow/health-baseline.json
